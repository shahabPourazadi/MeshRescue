# ─────────────────────────────────────────────────────────────────
# MeshRescue Edge AI Triage — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── Inference Settings ────────────────────────────────────────────

# How often (seconds) the drone auto-captures a frame for analysis
# Set to 0 to disable auto-capture (manual trigger only)
AUTO_TRIGGER_PERIOD_SEC=20

# Gemma 4 model variant to load via Cactus
# Options: gemma4:e2b  (2B, fastest, ~4.6GB)
#          gemma4:e4b  (4B, more capable, ~8GB)
LLM_MODEL=gemma4:e2b

# ── Sensor Modules ────────────────────────────────────────────────

# Enable/disable individual sensor inputs fed into the triage prompt
ENABLE_POSE=true       # MediaPipe body pose (upright, supine, sitting)
ENABLE_HAND=true       # MediaPipe hand gesture (open_palm, victory, etc.)
ENABLE_AUDIO=true      # 8-second ambient audio clip via Gemma 4 audio encoder
ENABLE_ENV=false       # Environment detection (experimental)

# ── GPS / Location ────────────────────────────────────────────────

# Baseline GPS coordinates for the Compute Node (used if browser GPS is unavailable)
# Format: decimal degrees, comma-separated  e.g. 34.05220, -118.24370
# This seeds the Commander map on startup and is the fallback for triage coordinates
EDGE_LOCATION=YOUR_LAT, YOUR_LNG

# ── Network ───────────────────────────────────────────────────────

# URL of the FastAPI backend (same machine = localhost)
# Change to http://[PI_IP]:8000 if running compute on a Raspberry Pi
COMMANDER_HUB_URL=http://localhost:8000

# ── LoRa / Meshtastic Radio (optional) ───────────────────────────

# Serial port of a connected Meshtastic device
# When set, Gemma 4's dispatch_rescue_team function call will transmit
# a real text message over the LoRa mesh network
# Leave blank to run in simulated mode (dispatch logged, not transmitted)
# Examples:
#   macOS:  /dev/tty.usbmodem1234
#   Linux:  /dev/ttyUSB0
#   RPi:    /dev/ttyAMA0
LORA_DEVICE=

# ── HuggingFace (model download) ─────────────────────────────────

# HuggingFace User Access Token — required to download Gemma 4 weights
# Get yours at: https://huggingface.co/settings/tokens
# Must have "Read" access and accepted the Gemma 4 model license at:
# https://huggingface.co/google/gemma-4-e2b-it
HF_TOKEN=hf_YOUR_TOKEN_HERE
